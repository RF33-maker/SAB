entrypoint = "app/main.py"
modules = ["nodejs-20", "python-3.11", "postgresql-16"]

[env]
PYTHONUNBUFFERED = "1"
PYTHONPATH = "."

[interpreter]
command = ["python3", "-u", "app/main.py"]

[unitTest]
language = "python"

[nix]
channel = "stable-24_05"
packages = ["glibcLocales", "python311Full", "xcodebuild", "zlib"]

[deployment]
run = ["python3", "app/main.py"]
deploymentTarget = "cloudrun"

[[ports]]
localPort = 5000
externalPort = 80

[[ports]]
localPort = 8099
externalPort = 8099

[agent]
expertMode = true

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Flask API Server"

[[workflows.workflow]]
name = "Flask API Server"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "python app/main.py"

[workflows.workflow.metadata]
outputType = "console"
